# Copy this to .env and fill in your values
# Used by docker-compose

# If self-hosting the relay server, set these to your domain
# For local dev, leave as-is (localhost)
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080

# For production with TLS (after setting up Caddyfile):
# NEXT_PUBLIC_WS_URL=wss://relay.yourdomain.com
# NEXT_PUBLIC_API_URL=https://relay.yourdomain.com
