FROM golang:1.22-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /infracanvas-server ./cmd/infracanvas-server

FROM alpine:3.19
RUN apk add --no-cache ca-certificates wget
COPY --from=builder /infracanvas-server /infracanvas-server
EXPOSE 8080
ENTRYPOINT ["/infracanvas-server"]
